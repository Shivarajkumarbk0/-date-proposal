<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Date Proposal ❤️</title>
<style>
body{
margin:0;
font-family:Arial,sans-serif;
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(135deg,#ffdde1,#ee9ca7);
overflow:hidden;
}
.card{
background:white;
padding:30px;
border-radius:24px;
text-align:center;
width:340px;
box-shadow:0 20px 50px rgba(0,0,0,.15);
}
h1{
font-size:28px;
}
.buttons{
position:relative;
height:100px;
margin-top:20px;
}
button{
padding:12px 22px;
border:none;
border-radius:999px;
font-size:18px;
cursor:pointer;
}
.yes{
background:#ff4d88;
color:white;
margin-right:12px;
}
.no{
position:absolute;
background:#eee;
left:190px;
top:0;
}
.hidden{
display:none;
}
form{
display:flex;
flex-direction:column;
gap:12px;
margin-top:18px;
}
input,select{
padding:12px;
border-radius:10px;
border:1px solid #ddd;
}
.checks{
display:grid;
grid-template-columns:1fr 1fr;
text-align:left;
}
.submit{
background:#ff4d88;
color:white;
}
.done{
font-size:22px;
color:#ff4d88;
}
</style>
</head>
<body>
<div class="card">
<div id="proposal">
<h1>Will you go on a date with me? ❤️</h1>
<div class="buttons">
<button class="yes" onclick="showForm()">YES 💘</button>
<button class="no" id="noBtn">NO 🙈</button>
</div>
</div>
<div id="formBox" class="hidden">
<h2>Plan our date ✨</h2>
<form id="dateForm">
<input type="date" required>
<input type="time" required>
<select required>
<option value="">Choose mood</option>
<option>Club 🎵</option>
<option>Food 🍽️</option>
<option>Pizza 🍕</option>
<option>Beer 🍺</option>
<option>Drinks 🍹</option>
<option>Movie 🎬</option>
</select>
<div class="checks">
<label><input type="checkbox"> Pizza 🍕</label>
<label><input type="checkbox"> Drinks 🍹</label>
<label><input type="checkbox"> Club 🎵</label>
<label><input type="checkbox"> Dessert 🍰</label>
</div>
<input type="text" placeholder="Anything she wants to say">
<button class="submit">
Send ❤️
</button>
</form>
</div>
<div id="success" class="hidden">
<div class="done">
Date request sent 💘
</div>
</div>
</div>
<script>
const noBtn=document.getElementById("noBtn");
noBtn.addEventListener("mouseover",()=>{
const x=Math.random()*(window.innerWidth-150);
const y=Math.random()*(window.innerHeight-100);
noBtn.style.left=x+"px";
noBtn.style.top=y+"px";
});
function showForm(){
document.getElementById("proposal").classList.add("hidden");
document.getElementById("formBox").classList.remove("hidden");
}
document
.getElementById("dateForm")
.addEventListener("submit",(e)=>{
e.preventDefault();
/*
SEND DATA TO:
Firebase
Google Sheets
Supabase
EmailJS
*/
document
.getElementById("formBox")
.classList.add("hidden");
document
.getElementById("success")
.classList.remove("hidden");
});
</script>
</body>
</html>
